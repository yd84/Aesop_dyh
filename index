<!DOCTYPE html>
<html lang="zh-Hans">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Vectoria | Responsive Product Page</title>
  <style>
    :root {
      --bg: #efe8dc;
      --panel: #e8dfd2;
      --panel-deep: #e5dac9;
      --ink: #27231e;
      --ink-2: #3d352b;
      --muted: #5e5548;
      --muted-2: #6b6153;
      --cream: #efe8dc;
      --dark: #2e2923;
      --footer: #27231e;
      --line: rgba(61, 53, 43, 0.14);
      --line-strong: rgba(61, 53, 43, 0.22);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      min-height: 100vh;
      background: var(--bg);
      color: var(--ink);
      font-family: Arial, "Noto Sans SC", "Microsoft YaHei", sans-serif;
      -webkit-font-smoothing: antialiased;
      text-rendering: geometricPrecision;
    }
    body.drawer-lock { overflow: hidden; }
    a { color: inherit; text-decoration: none; }
    button {
      font: inherit;
      color: inherit;
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
    }
    button:focus-visible, a:focus-visible {
      outline: 2px solid rgba(39, 35, 30, 0.45);
      outline-offset: 3px;
    }
    ::selection { background: var(--ink); color: var(--cream); }

    .marquee-bar {
      position: fixed;
      left: 0;
      right: 0;
      top: 0;
      z-index: 40;
      overflow: hidden;
      background: var(--dark);
      color: var(--cream);
      padding: 10px 0;
    }
    @keyframes seamless-marquee {
      from { transform: translate3d(0, 0, 0); }
      to { transform: translate3d(-50%, 0, 0); }
    }
    .marquee-track {
      display: flex;
      width: max-content;
      white-space: nowrap;
      font-size: 12px;
      letter-spacing: 0.04em;
      animation: seamless-marquee 136s linear infinite;
      will-change: transform;
    }
    .marquee-group { display: flex; flex-shrink: 0; }
    .marquee-item { margin: 0 28px; }

    .site-header {
      position: fixed;
      left: 0;
      right: 0;
      top: 37px;
      z-index: 40;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid rgba(61, 53, 43, 0.12);
      background: rgba(239, 232, 220, 0.92);
      backdrop-filter: blur(14px);
      padding: 0 16px;
    }
    .brand {
      margin-right: auto;
      font-size: 16px;
      letter-spacing: 0.12em;
      font-weight: 400;
    }
    .desktop-nav {
      display: none;
      align-items: center;
      gap: 32px;
      font-size: 13px;
    }
    .desktop-nav a:hover, .header-action:hover { opacity: 0.6; }
    .header-actions { display: flex; align-items: center; gap: 8px; font-size: 13px; }
    .header-action {
      display: flex;
      align-items: center;
      gap: 8px;
      transition: opacity 0.2s ease, background 0.2s ease;
    }
    .icon-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
      border-radius: 999px;
      transition: background 0.2s ease;
    }
    .icon-btn:hover { background: rgba(61, 53, 43, 0.08); }
    .mobile-menu-btn { margin-right: 12px; }
    .hide-on-mobile { display: none; }

    main { padding-top: 101px; padding-bottom: 96px; }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr;
    }
    .gallery {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: rgba(61, 53, 43, 0.12);
    }
    .gallery-btn { display: block; width: 100%; text-align: left; overflow: hidden; }

    .product-visual {
      position: relative;
      overflow: hidden;
      min-height: 320px;
      background: var(--panel);
    }
    .product-visual.large { min-height: 460px; }
    .product-visual.compact { width: 100%; height: 100%; min-height: 0; }
    .visual-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 35%, rgba(255,248,230,0.9), rgba(216,203,184,0.55) 35%, rgba(189,174,151,0.28) 63%, transparent 72%);
    }
    .visual-bottom {
      position: absolute;
      inset: auto 0 0 0;
      height: 50%;
      background: linear-gradient(to top, rgba(198,183,158,0.4), transparent);
    }
    .visual-object {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transform: translateY(18px);
      opacity: 0;
      transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.8s ease;
    }
    .product-visual.in-view .visual-object,
    .product-visual.compact .visual-object {
      transform: translateY(0);
      opacity: 1;
    }
    .visual-core {
      position: relative;
      height: 58%;
      width: 54%;
      min-width: 210px;
      max-width: 420px;
    }
    .product-visual.compact .visual-core { height: 76%; width: 76%; min-width: 0; }
    .lamp-ring {
      position: absolute;
      left: 50%;
      top: 8%;
      height: 46%;
      width: 46%;
      transform: translateX(-50%);
      border-radius: 999px;
      border: 1px solid rgba(77, 70, 61, 0.2);
      background: rgba(245, 238, 224, 0.7);
      box-shadow: 0 30px 80px rgba(60,47,35,0.22);
      backdrop-filter: blur(3px);
    }
    .lamp-glow {
      position: absolute;
      left: 50%;
      top: 19%;
      height: 32%;
      width: 32%;
      transform: translateX(-50%);
      border-radius: 999px;
      background: rgba(255, 246, 220, 0.7);
      filter: blur(18px);
    }
    .lamp-neck {
      position: absolute;
      left: 50%;
      top: 47%;
      height: 28%;
      width: 13%;
      transform: translateX(-50%);
      border-radius: 999px 999px 0 0;
      background: linear-gradient(to bottom, #8b785c, #5f513e, #302a22);
      box-shadow: 0 25px 50px rgba(44,35,26,0.32);
    }
    .lamp-base {
      position: absolute;
      left: 50%;
      top: 69%;
      height: 9%;
      width: 54%;
      transform: translateX(-50%);
      border-radius: 999px;
      background: linear-gradient(to right, #332c22, #8c795d, #332c22);
      box-shadow: 0 16px 40px rgba(44,35,26,0.32);
    }
    .lamp-shadow {
      position: absolute;
      left: 50%;
      top: 79%;
      height: 5%;
      width: 78%;
      transform: translateX(-50%);
      border-radius: 999px;
      background: rgba(44, 38, 31, 0.8);
      filter: blur(1px);
    }
    .axis-x {
      position: absolute;
      left: 50%;
      top: 36%;
      height: 1px;
      width: 120%;
      transform: translateX(-50%);
      background: rgba(77, 70, 61, 0.2);
    }
    .axis-y {
      position: absolute;
      left: 50%;
      top: 36%;
      height: 120%;
      width: 1px;
      transform: translateX(-50%);
      background: rgba(77, 70, 61, 0.16);
    }
    .visual-label {
      position: absolute;
      left: 20px;
      top: 20px;
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(75, 68, 57, 0.7);
    }
    .visual-ring {
      position: absolute;
      right: 20px;
      bottom: 20px;
      width: 56px;
      height: 56px;
      border: 1px solid rgba(61, 53, 43, 0.25);
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--ink-2);
      font-size: 12px;
    }

    .hero-panel {
      padding: 32px 20px;
    }
    .eyebrow {
      margin: 0 0 16px;
      font-size: 12px;
      letter-spacing: 0.12em;
      color: var(--muted);
    }
    .hero-title {
      margin: 0 0 24px;
      font-size: clamp(40px, 11vw, 54px);
      line-height: 0.94;
      letter-spacing: -0.05em;
      font-weight: 400;
    }
    .copy-block {
      color: #4d463d;
      font-size: 15px;
      line-height: 2;
    }
    .copy-block p { margin: 0 0 20px; }
    .link-button {
      border-bottom: 1px solid var(--ink);
      padding-bottom: 2px;
    }
    .hidden-copy {
      height: 0;
      opacity: 0;
      overflow: hidden;
      transition: height 0.28s ease, opacity 0.28s ease;
    }
    .hidden-copy.open { opacity: 1; }

    .variant-box {
      margin-top: 32px;
      border-top: 1px solid rgba(61,53,43,0.18);
      border-bottom: 1px solid rgba(61,53,43,0.18);
      padding: 24px 0;
    }
    .variant-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 20px;
    }
    .variant-head span:first-child { font-size: 14px; color: var(--muted); }
    .variant-price { font-size: 18px; }
    .variant-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .variant-btn {
      min-height: 48px;
      border: 1px solid rgba(61, 53, 43, 0.2);
      padding: 0 12px;
      text-align: left;
      font-size: 13px;
      transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
    }
    .variant-btn:hover { border-color: var(--ink); }
    .variant-btn.selected {
      background: var(--ink);
      color: var(--cream);
      border-color: var(--ink);
    }
    .primary-btn {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      height: 56px;
      margin-top: 24px;
      padding: 0 20px;
      background: var(--ink);
      color: var(--cream);
      font-size: 14px;
      transition: background 0.2s ease;
    }
    .primary-btn:hover { background: #171411; }
    .desktop-only-btn { display: none; }
    .note {
      margin-top: 24px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.85;
    }
    .note p { margin: 0; }

    .section {
      border-top: 1px solid rgba(61,53,43,0.12);
      padding: 64px 20px;
    }
    .section-inner {
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .section-title {
      max-width: 430px;
      margin: 0;
      font-size: clamp(32px, 8vw, 48px);
      line-height: 1.05;
      letter-spacing: -0.04em;
      font-weight: 400;
    }
    .craft-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: rgba(61,53,43,0.16);
    }
    .craft-card {
      min-height: 240px;
      background: var(--bg);
      padding: 24px;
      transform: translateY(20px);
      opacity: 0;
      transition: transform 0.6s ease, opacity 0.6s ease;
    }
    .craft-card.in-view { transform: translateY(0); opacity: 1; }
    .craft-index {
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      border: 1px solid rgba(61,53,43,0.22);
      font-size: 13px;
      margin-bottom: 32px;
    }
    .craft-card h3 {
      margin: 0 0 12px;
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.03em;
    }
    .craft-place {
      margin: 0 0 24px;
      font-size: 13px;
      color: var(--muted-2);
    }
    .craft-copy {
      margin: 0;
      color: #4d463d;
      font-size: 14px;
      line-height: 1.9;
    }

    .specs-grid {
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .spec-visual-wrap {
      background: var(--panel-deep);
      padding: 16px;
    }
    .accordion-group { align-self: center; }
    .accordion {
      border-top: 1px solid rgba(61,53,43,0.18);
      padding: 20px 0;
    }
    .accordion-trigger {
      display: flex;
      width: 100%;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      text-align: left;
      font-weight: 500;
      font-size: 15px;
    }
    .chevron { transition: transform 0.24s ease; }
    .accordion.open .chevron { transform: rotate(180deg); }
    .accordion-body {
      overflow: hidden;
      max-height: 0;
      opacity: 0;
      transition: max-height 0.32s ease, opacity 0.26s ease;
      color: #4d463d;
      font-size: 14px;
      line-height: 1.9;
    }
    .accordion.open .accordion-body { max-height: 720px; opacity: 1; }
    .accordion-content { padding-top: 16px; }
    .data-row {
      display: grid;
      grid-template-columns: 1fr;
      gap: 4px;
      border-bottom: 1px solid rgba(61,53,43,0.12);
      padding: 12px 0;
    }
    .data-row span:first-child { color: var(--muted-2); }

    .quote-section {
      border-top: 1px solid rgba(61,53,43,0.12);
      border-bottom: 1px solid rgba(61,53,43,0.12);
      padding: 80px 20px;
      text-align: center;
    }
    .quote-text {
      max-width: 900px;
      margin: 0 auto;
      font-size: clamp(30px, 9vw, 56px);
      line-height: 1.05;
      letter-spacing: -0.04em;
      font-weight: 400;
    }
    .quote-source {
      margin: 32px 0 0;
      font-size: 12px;
      letter-spacing: 0.16em;
      color: var(--muted-2);
    }

    .footer {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: rgba(61,53,43,0.16);
    }
    .footer-card {
      min-height: 190px;
      background: var(--footer);
      color: var(--cream);
      padding: 28px;
    }
    .footer-card h4 {
      margin: 0 0 28px;
      font-size: 15px;
      font-weight: 400;
    }
    .footer-card p {
      margin: 0 0 12px;
      font-size: 13px;
      color: #cfc4b3;
    }

    .mobile-sticky {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 40;
      border-top: 1px solid rgba(61,53,43,0.14);
      background: rgba(239,232,220,0.95);
      backdrop-filter: blur(14px);
      padding: 16px 16px calc(var(--safe-bottom) + 16px);
    }
    .mobile-sticky .primary-btn { margin: 0; height: auto; min-height: 52px; padding-top: 14px; padding-bottom: 14px; }

    .drawer-overlay,
    .lightbox {
      position: fixed;
      inset: 0;
      z-index: 50;
      background: rgba(0,0,0,0.3);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.28s ease;
    }
    .drawer-overlay.open,
    .lightbox.open { opacity: 1; pointer-events: auto; }
    .drawer {
      margin-left: auto;
      height: 100%;
      width: 100%;
      max-width: 448px;
      display: flex;
      flex-direction: column;
      background: var(--bg);
      box-shadow: 0 24px 80px rgba(0,0,0,0.24);
      transform: translateX(100%);
      transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .drawer.small { max-width: 384px; }
    .drawer-overlay.open .drawer { transform: translateX(0); }
    .drawer-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid rgba(61,53,43,0.14);
      padding: 24px;
    }
    .drawer-head h3 { margin: 0; font-size: 20px; font-weight: 400; }
    .drawer-body { flex: 1; overflow-y: auto; padding: 24px; }
    .drawer-foot {
      border-top: 1px solid rgba(61,53,43,0.14);
      padding: 24px 24px calc(var(--safe-bottom) + 24px);
    }
    .drawer-menu a {
      display: block;
      border-bottom: 1px solid rgba(61,53,43,0.12);
      padding: 16px 0;
      font-size: 22px;
      letter-spacing: -0.03em;
    }
    .drawer-subaction {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 32px;
      font-size: 14px;
      color: var(--muted);
    }
    .field-label {
      margin: 0 0 12px;
      color: var(--muted-2);
      font-size: 13px;
    }
    .option-list, .language-grid { display: grid; gap: 8px; }
    .option-list { margin-bottom: 32px; }
    .option-btn {
      border: 1px solid rgba(61,53,43,0.18);
      padding: 12px 16px;
      text-align: left;
      font-size: 14px;
    }
    .option-btn:hover { border-color: var(--ink); }
    .cart-row {
      display: flex;
      gap: 16px;
      border-bottom: 1px solid rgba(61,53,43,0.14);
      padding-bottom: 24px;
    }
    .cart-thumb {
      width: 96px;
      height: 96px;
      flex: none;
      overflow: hidden;
      background: #e1d5c2;
    }
    .cart-info { min-width: 0; flex: 1; }
    .cart-title { margin: 0 0 4px; font-size: 15px; }
    .cart-label { margin: 0 0 16px; font-size: 13px; color: var(--muted-2); }
    .qty { display: flex; align-items: center; gap: 12px; }
    .qty button {
      width: 23px;
      height: 23px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      border: 1px solid rgba(61,53,43,0.2);
    }
    .cart-price { margin: 0; font-size: 14px; }

    .lightbox {
      z-index: 60;
      background: rgba(21,18,15,0.95);
      padding: 16px;
    }
    .lightbox-inner {
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .lightbox-card {
      width: min(100%, 900px);
      overflow: hidden;
      border-radius: 2px;
    }
    .lightbox-close {
      position: absolute;
      right: 16px;
      top: 16px;
      z-index: 2;
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.2);
      color: var(--cream);
    }

    .svg-icon { width: 18px; height: 18px; display: inline-block; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
    .svg-sm { width: 14px; height: 14px; }

    @media (min-width: 640px) {
      .marquee-bar { padding: 12px 0; }
      .marquee-track { font-size: 13px; }
      .marquee-item { margin: 0 40px; }
      .site-header { top: 41px; height: 80px; padding: 0 24px; }
      main { padding-top: 121px; }
      .brand { font-size: 18px; }
      .product-visual { min-height: 420px; }
      .product-visual.large { min-height: 560px; }
      .visual-label { left: 32px; top: 32px; font-size: 12px; }
      .visual-ring { right: 32px; bottom: 32px; width: 80px; height: 80px; font-size: 14px; }
      .visual-core { min-width: 240px; }
      .hero-panel { padding: 40px 32px; }
      .variant-grid { grid-template-columns: 1fr 1fr; }
      .section { padding: 80px 24px; }
      .craft-card { min-height: 280px; padding: 32px; }
      .craft-index { width: 48px; height: 48px; margin-bottom: 40px; }
      .craft-card h3 { font-size: 24px; }
      .craft-place { margin-bottom: 32px; }
      .spec-visual-wrap { padding: 32px; }
      .data-row { grid-template-columns: 42% 58%; gap: 0; }
      .quote-section { padding: 96px 24px; }
      .quote-source { font-size: 14px; }
      .footer { grid-template-columns: 1fr 1fr; }
      .footer-card { min-height: 220px; padding: 32px; }
      .drawer-head, .drawer-body { padding: 32px; }
      .drawer-foot { padding: 32px 32px calc(var(--safe-bottom) + 32px); }
      .drawer-head h3 { font-size: 22px; }
      .language-grid { grid-template-columns: 1fr 1fr; }
      .cart-row { gap: 20px; }
      .lightbox { padding: 24px; }
      .lightbox-close { right: 24px; top: 24px; }
    }

    @media (min-width: 768px) {
      .site-header { padding: 0 40px; }
      .mobile-menu-btn { display: none; }
      .desktop-nav { display: flex; }
      .hide-on-mobile { display: inline-flex; }
      .brand { margin-right: 0; }
      .gallery { grid-template-columns: 1fr 1fr; }
      .gallery-btn:first-child { grid-column: span 2; }
      .craft-grid { grid-template-columns: 1fr 1fr; }
      .section { padding-left: 48px; padding-right: 48px; }
      .quote-section { padding-left: 48px; padding-right: 48px; }
    }

    @media (min-width: 1024px) {
      main { padding-bottom: 0; }
      .hero-grid { grid-template-columns: 64% 36%; }
      .hero-panel-wrap {
        position: sticky;
        top: 121px;
        height: calc(100vh - 121px);
      }
      .hero-panel {
        min-height: 100%;
        padding: 40px 56px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }
      .product-visual { min-height: 520px; }
      .product-visual.large { min-height: 690px; }
      .desktop-only-btn { display: flex; }
      .mobile-sticky { display: none; }
      .section { padding: 96px 80px; }
      .section-inner { grid-template-columns: 36% 64%; gap: 64px; }
      .specs-grid { grid-template-columns: 1fr 1fr; gap: 40px; }
      .spec-visual-wrap { padding: 48px; }
      .quote-section { padding: 112px 48px; }
      .footer { grid-template-columns: repeat(4, 1fr); }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.001ms !important; animation-iteration-count: 1 !important; transition-duration: 0.001ms !important; scroll-behavior: auto !important; }
    }
  </style>
</head>
<body>
  <div class="marquee-bar" aria-label="欢迎字幕">
    <div class="marquee-track" id="marqueeTrack"></div>
  </div>

  <header class="site-header">
    <button class="icon-btn mobile-menu-btn" data-open-drawer="menu" aria-label="打开菜单">
