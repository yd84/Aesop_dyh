            <div class="qty">
              <button aria-label="减少"><svg class="svg-icon svg-sm" viewBox="0 0 24 24"><path d="M5 12h14"/></svg></button>
              <span>1</span>
              <button aria-label="增加"><svg class="svg-icon svg-sm" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></button>
