  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightboxClose" aria-label="关闭图片预览"><svg class="svg-icon" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg></button>
    <div class="lightbox-inner">
      <div class="lightbox-card" id="lightboxCard"></div>
    </div>
  </div>

  <script>
    const MARQUEE_TEXT = "歡迎來到東南大學電氣工程學院，於此獨家探索丁月恆的世界。";
    const labels = ["整体系统", "轮端协同", "控制算法", "验证平台"];
    const rings = ["78%", "58%", "68%", "48%"];
    const variants = [
      { id: "eu", label: "欧洲标准", price: "€2,850" },
      { id: "uk", label: "英美日标准", price: "€2,850" },
      { id: "cn", label: "中国/香港标准", price: "€2,850" },
      { id: "au", label: "澳洲标准", price: "€2,850" }
    ];
    const craftSteps = [
      { title: "系统建模", place: "动力学 · 多执行器耦合", copy: "从车身、轮端与电机三层结构出发，建立可解释的协同动力学模型，使每一次转矩分配都拥有清晰的物理依据。" },
      { title: "稳定性评估", place: "横摆角速度 · 质心侧偏角", copy: "将稳定裕度转化为连续可计算的评价量，实时识别车辆从安全域向极限域演化的过程。" },
      { title: "转矩矢量分配", place: "四轮独立驱动 · 约束优化", copy: "在轮胎附着、执行器能力和能效边界内，计算四个轮端的最优转矩组合，兼顾稳定、平顺与高效。" },
      { title: "半实物验证", place: "dSPACE · FPGA · CarSim", copy: "通过实时控制器、轮端电机仿真与整车模型闭环联调，验证算法在复杂工况下的工程可执行性。" }
    ];
    const specs = [
      ["应用对象", "四轮独立驱动电动汽车"],
      ["控制架构", "上层稳定性控制 / 中层优化决策 / 下层转矩分配"],
      ["核心变量", "横摆角速度、质心侧偏角、轮端转矩"],
      ["约束条件", "轮胎附着椭圆、转矩边界、功率限制、平顺性约束"],
      ["验证方式", "CarSim–Simulink 联合仿真与 dSPACE 半实物验证"],
      ["目标效果", "稳定性提升、能耗降低、转矩冲击抑制"]
    ];
    const dimensions = [
      ["系统层级", "3 层"],
      ["执行单元", "4 个轮端电机"],
      ["控制周期", "毫秒级"],
      ["接口对象", "车辆模型 / 电机模型 / 实时控制器"],
      ["适用工况", "低附着、双移线、故障重构"],
      ["输出形式", "四轮目标转矩"]
    ];
    const footerItems = [
      ["项目介绍", "系统概览", "核心优势", "应用场景"],
      ["技术支持", "验证平台", "算法说明", "常见问题"],
      ["合作方式", "联系团队", "预约演示", "成果转化"],
      ["法律信息", "隐私政策", "服务条款", "Cookie 政策"]
    ];

    let selectedVariant = "cn";

    function iconArrow() {
      return '<svg class="svg-icon svg-sm" viewBox="0 0 24 24"><path d="M7 17 17 7M8 7h9v9"/></svg>';
    }

    function productVisual(index, options = {}) {
      const cls = ["product-visual", options.large ? "large" : "", options.compact ? "compact" : ""].filter(Boolean).join(" ");
      return `
        <div class="${cls}" data-animate>
          <div class="visual-bg"></div>
          <div class="visual-bottom"></div>
          <div class="visual-object">
            <div class="visual-core">
              <div class="lamp-ring"></div>
              <div class="lamp-glow"></div>
              <div class="lamp-neck"></div>
              <div class="lamp-base"></div>
              <div class="lamp-shadow"></div>
              <div class="axis-x"></div>
              <div class="axis-y"></div>
            </div>
          </div>
          ${options.compact ? "" : `<div class="visual-label">${labels[index]}</div><div class="visual-ring">${rings[index]}</div>`}
        </div>`;
    }

    function renderInitial() {
      const marqueeTrack = document.getElementById("marqueeTrack");
      marqueeTrack.innerHTML = [0, 1].map(group => `
        <div class="marquee-group">
          ${Array.from({ length: 10 }).map((_, i) => `<span class="marquee-item">${MARQUEE_TEXT}</span>`).join("")}
        </div>
      `).join("");

      document.getElementById("gallery").innerHTML = [0, 1, 2, 3].map(index => `
        <button class="gallery-btn" data-lightbox-index="${index}">${productVisual(index, { large: index === 0 })}</button>
      `).join("");

      document.getElementById("variantGrid").innerHTML = variants.map(v => `
        <button class="variant-btn ${v.id === selectedVariant ? "selected" : ""}" data-variant="${v.id}">${v.label}</button>
      `).join("");

      document.getElementById("craftGrid").innerHTML = craftSteps.map((step, idx) => `
        <article class="craft-card" data-animate style="transition-delay:${idx * 80}ms">
          <div class="craft-index">0${idx + 1}</div>
          <h3>${step.title}</h3>
          <p class="craft-place">${step.place}</p>
          <p class="craft-copy">${step.copy}</p>
        </article>
      `).join("");

      document.getElementById("specVisual").innerHTML = productVisual(1);
      document.getElementById("cartThumb").innerHTML = productVisual(2, { compact: true });
      document.getElementById("dimensionsRows").innerHTML = dimensions.map(row => `<div class="data-row"><span>${row[0]}</span><span>${row[1]}</span></div>`).join("");
      document.getElementById("specRows").innerHTML = specs.map(row => `<div class="data-row"><span>${row[0]}</span><span>${row[1]}</span></div>`).join("");
      document.getElementById("footer").innerHTML = footerItems.map(item => `
        <div class="footer-card"><h4>${item[0]}</h4><p>${item[1]}</p><p>${item[2]}</p><p>${item[3]}</p></div>
      `).join("");
    }

    function updateVariant(id) {
      selectedVariant = id;
      const variant = variants.find(v => v.id === id) || variants[0];
      document.getElementById("variantPrice").textContent = variant.price;
      document.getElementById("cartLabel").textContent = variant.label;
      document.querySelectorAll(".variant-btn").forEach(btn => {
        btn.classList.toggle("selected", btn.dataset.variant === id);
      });
    }

    function getDrawer(id) {
      return document.getElementById(`${id}Drawer`);
    }
    function openDrawer(id) {
      closeAllDrawers(false);
      const drawer = getDrawer(id);
      if (!drawer) return;
      drawer.classList.add("open");
      drawer.setAttribute("aria-hidden", "false");
      document.body.classList.add("drawer-lock");
    }
    function closeAllDrawers(unlock = true) {
      document.querySelectorAll(".drawer-overlay").forEach(drawer => {
        drawer.classList.remove("open");
        drawer.setAttribute("aria-hidden", "true");
      });
      if (unlock) document.body.classList.remove("drawer-lock");
    }

    function openLightbox(index) {
      const lightbox = document.getElementById("lightbox");
      document.getElementById("lightboxCard").innerHTML = productVisual(Number(index), { large: true });
      lightbox.classList.add("open");
      lightbox.setAttribute("aria-hidden", "false");
      document.body.classList.add("drawer-lock");
      requestAnimationFrame(() => {
        const visual = document.querySelector("#lightboxCard .product-visual");
        if (visual) visual.classList.add("in-view");
      });
    }
    function closeLightbox() {
      const lightbox = document.getElementById("lightbox");
      lightbox.classList.remove("open");
      lightbox.setAttribute("aria-hidden", "true");
      document.body.classList.remove("drawer-lock");
    }

    function setupEvents() {
      document.addEventListener("click", (event) => {
        const openBtn = event.target.closest("[data-open-drawer]");
        if (openBtn) openDrawer(openBtn.dataset.openDrawer);

        const switchBtn = event.target.closest("[data-switch-drawer]");
        if (switchBtn) openDrawer(switchBtn.dataset.switchDrawer);

        const closeBtn = event.target.closest("[data-close-drawer]");
        if (closeBtn) closeAllDrawers();

        const overlay = event.target.classList && event.target.classList.contains("drawer-overlay") ? event.target : null;
        if (overlay) closeAllDrawers();

        const variantBtn = event.target.closest("[data-variant]");
        if (variantBtn) updateVariant(variantBtn.dataset.variant);

        const lightboxBtn = event.target.closest("[data-lightbox-index]");
        if (lightboxBtn) openLightbox(lightboxBtn.dataset.lightboxIndex);
      });

      document.getElementById("lightboxClose").addEventListener("click", closeLightbox);
      document.getElementById("lightbox").addEventListener("click", (event) => {
        if (event.target.id === "lightbox") closeLightbox();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeAllDrawers();
          closeLightbox();
        }
      });

      document.querySelectorAll(".accordion-trigger").forEach(trigger => {
        trigger.addEventListener("click", () => {
          trigger.closest(".accordion").classList.toggle("open");
        });
      });

      const hiddenCopy = document.getElementById("hiddenCopy");
      const readMoreBtn = document.getElementById("readMoreBtn");
      readMoreBtn.addEventListener("click", () => {
        const open = hiddenCopy.classList.toggle("open");
        if (open) {
          hiddenCopy.style.height = hiddenCopy.scrollHeight + "px";
          readMoreBtn.textContent = "收起";
        } else {
          hiddenCopy.style.height = hiddenCopy.scrollHeight + "px";
          requestAnimationFrame(() => { hiddenCopy.style.height = "0px"; });
          readMoreBtn.textContent = "展开阅读";
        }
      });
      window.addEventListener("resize", () => {
        if (hiddenCopy.classList.contains("open")) hiddenCopy.style.height = hiddenCopy.scrollHeight + "px";
      });
    }

    function setupObserver() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.18, rootMargin: "0px 0px -80px 0px" });
      document.querySelectorAll("[data-animate]").forEach(el => observer.observe(el));
    }

    renderInitial();
    setupEvents();
    setupObserver();
  </script>
</body>
</html>
