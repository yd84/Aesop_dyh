  <div class="drawer-overlay" id="cartDrawer" aria-hidden="true">
    <div class="drawer" role="dialog" aria-modal="true" aria-label="预约清单">
      <div class="drawer-head">
        <h3>预约清单</h3>
        <button class="icon-btn" data-close-drawer aria-label="关闭预约清单"><svg class="svg-icon" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg></button>
      </div>
      <div class="drawer-body">
        <div class="cart-row">
          <div class="cart-thumb" id="cartThumb"></div>
          <div class="cart-info">
            <p class="cart-title">Vectoria 协同控制系统</p>
